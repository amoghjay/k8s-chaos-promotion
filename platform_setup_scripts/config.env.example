# platform_setup_scripts config — copy to config.env and edit
#
#   cp config.env.example config.env
#   $EDITOR config.env
#
# Then either:
#   make bootstrap                       # fresh setup (prompts for secret values)
#   make migrate SOURCE=amoghdevops      # migrate from another GCP project

# ---------- required ----------

# New GCP project — the target of this bootstrap
PROJECT_ID="ajprojectplatform"

# Auto-detected if unset:
#   PROJECT_NUMBER=$(gcloud projects describe $PROJECT_ID --format='value(projectNumber)')
PROJECT_NUMBER=""

# ---------- mostly stable defaults ----------

REGION="us-central1"
ZONE="us-central1-a"
CLUSTER_NAME="chaos-promotion"
GAR_REPO="k8s-chaos-demo"
GITHUB_REPO="amoghjay/k8s-chaos-promotion"
TF_STATE_BUCKET="${PROJECT_ID}-tf-state"

# Helm versions (pin for reproducibility)
CERT_MANAGER_VERSION="v1.16.2"
ESO_VERSION=""              # latest if blank
KARGO_CHART="oci://ghcr.io/akuity/kargo-charts/kargo"

# ---------- secrets migration (only when --source-project is used) ----------

# SOURCE_PROJECT and SOURCE_ACCOUNT are passed via bootstrap.sh flags:
#   --source-project amoghdevops --source-account amoghjay.us@gmail.com
# You don't set these here.

# List of secrets the bootstrap creates / migrates. Add or remove as needed.
SECRETS=(
  database-password
  github-pat
  grafana-admin-password
  radius-rpc-url-testnet
  radius-rpc-url-mainnet
  service-wallet-address-testnet
  service-wallet-address-mainnet
  load-test-wallet-key-1
  load-test-wallet-key-2
  load-test-wallet-key-3
)
